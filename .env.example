# NapCat Group Info MCP Server 配置示例

# NapCat OneBot 服务器地址
NAPCAT_HOST=http://localhost:3000

# NapCat 访问令牌（如果配置了鉴权）
NAPCAT_TOKEN=your_token_here

# 允许访问的群号列表
# 支持以下几种配置方式：
# 1. 留空或不设置：允许访问所有群
# 2. 设置为 "all" 或 "*"：允许访问所有群
# 3. 设置为逗号分隔的群号列表：只允许这些群
#
# 示例：
# ALLOWED_GROUPS=                    # 允许所有群
# ALLOWED_GROUPS=all                 # 允许所有群
# ALLOWED_GROUPS=*                   # 允许所有群
# ALLOWED_GROUPS=628101497           # 只允许群 628101497
# ALLOWED_GROUPS=628101497,123456789 # 允许群 628101497 和 123456789

ALLOWED_GROUPS=628101497

# 示例：连接到远程 NapCat 服务器
# NAPCAT_HOST=http://192.168.1.100:3000
# NAPCAT_TOKEN=your_remote_token